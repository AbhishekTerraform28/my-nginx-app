pipeline {

agent any 

stages {

    stage ('checkout from the repostiroy'){
        steps {
        git url: 'https://github.com/AbhishekTerraform28/my-nginx-app.git', branch: 'main'
        echo "github url repos read done"
    } }

stage ('building the image by file again'){
    steps {
        echo "code till run here"
               sh 'docker build -f DockerFile -t my-nginx:v1 .'

    }
}

 stage ('Run Container'){
 steps {
     sh '''
                docker stop my-nginx || true
                docker rm my-nginx || true
                docker run -d --name my-nginx -p 80:80 my-nginx:v1
                '''
 } 
 }


}


}