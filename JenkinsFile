pipeline {

agent any 

stages {

    stage ('checkout from the repostiroy'){
        steps {
        git url: 'https://github.com/AbhishekTerraform28/my-nginx-app.git', branch: 'main'
        echo "github url repos read done"
    } }


stage('SonarQube Analysis') {
    environment {
        SONAR_SCANNER_OPTS = '-Xmx512m'
    }
    steps {
        withSonarQubeEnv('SonarQube') {
            sh "${tool 'SonarScanner'}/bin/sonar-scanner"
        }
    }
}


stage('Quality Gate') {
    steps {
        timeout(time: 5, unit: 'MINUTES') {
            waitForQualityGate abortPipeline: true
        }
    }
}


stage ('building the image by file again'){
    steps {
        echo "code till run here"
               sh 'docker build -f DockerFile -t my-nginx:v1 .'

    }
}

 stage ('Run Container'){
 steps {
     sh '''
                docker stop my-nginx || true
                docker rm my-nginx || true
                docker run -d --name my-nginx -p 81:80 my-nginx:v1
                '''
 } 
 }

stage('Login to ECR') {
    steps {
        sh '''
        aws ecr get-login-password --region us-east-1 | \
        docker login --username AWS --password-stdin 891377082810.dkr.ecr.us-east-1.amazonaws.com
        '''
    }
}

stage('Tag Docker Image') {
    steps {
        sh 'docker tag my-nginx:v1 891377082810.dkr.ecr.us-east-1.amazonaws.com/my-nginx-app:v1'
    }
}

stage('Push Docker Image') {
    steps {
        sh 'docker push 891377082810.dkr.ecr.us-east-1.amazonaws.com/my-nginx-app:v1'
    }
}

}


}
